{
  "name": "@jobhunt/api",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "serve": "tsx src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:boot-contract": "npm run build && node --test dist/server/http-server.test.js",
    "test:prompt-contract": "npm run build && node --test dist/prompt/prompt-loader.test.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
