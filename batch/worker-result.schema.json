{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobhunt.local/batch/worker-result.schema.json",
  "title": "jobhunt batch worker result",
  "description": "Permissive response-format schema for codex exec; batch-runner.sh performs strict post-run validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "id",
    "report_num",
    "company",
    "role",
    "score",
    "legitimacy",
    "pdf",
    "report",
    "tracker",
    "warnings",
    "error"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "failed"]
    },
    "id": {
      "type": "string"
    },
    "report_num": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "score": {
      "type": ["number", "null"]
    },
    "legitimacy": {
      "type": ["string", "null"]
    },
    "pdf": {
      "type": ["string", "null"]
    },
    "report": {
      "type": ["string", "null"]
    },
    "tracker": {
      "type": ["string", "null"]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": ["string", "null"]
    }
  }
}
